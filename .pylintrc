[MAIN]
ignore=.venv
ignore-patterns=.*migrations.*
jobs=0
py-version=3.10

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods

[FORMAT]
max-line-length=120

[BASIC]
good-names=i,j,k,ex,Run,_,pk,id

[DESIGN]
max-args=8
max-positional-arguments=8
min-similarity-lines=15

[TYPECHECK]
generated-members=objects,DoesNotExist,MultipleObjectsReturned,id,pk,_meta
